#include <stdio.h>

int main()
{
    char str1[100], str2[50];
    char *p1, *p2;

    printf("Enter first string: ");
    gets(str1);

    printf("Enter second string: ");
    gets(str2);

    p1 = str1;
    p2 = str2;

    // Move pointer to end of first string
    while(*p1 != '\0')
        p1++;

    // Copy second string to first
    while(*p2 != '\0')
    {
        *p1 = *p2;
        p1++;
        p2++;
    }

    *p1 = '\0';

    printf("Concatenated string: %s", str1);

    return 0;
}
