#include <stdio.h>

int main()
{
    int n, i, j, temp, k;

    printf("Enter size: ");
    scanf("%d", &n);

    int a[100];   // fixed size (safer for online compiler)

    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    printf("Enter k: ");
    scanf("%d", &k);

    if(k > n || k <= 0)
    {
        printf("Invalid k");
        return 0;
    }

    // Sorting (ascending)
    for(i = 0; i < n-1; i++)
    {
        for(j = i+1; j < n; j++)
        {
            if(a[i] > a[j])
            {
                temp = a[i];
                a[i] = a[j];
                a[j] = temp;
            }
        }
    }

    printf("Kth smallest = %d\n", a[k-1]);
    printf("Kth largest = %d", a[n-k]);

    return 0;
}
