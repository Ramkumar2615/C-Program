#include <stdio.h>

int main()
{
    int n, i, temp;
    int a[100];

    printf("Enter size: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &a[i]);

    // Store last element
    temp = a[n-1];

    // Shift elements to right
    for(i = n-1; i > 0; i--)
        a[i] = a[i-1];

    // Place last element at first
    a[0] = temp;

    printf("Array after right rotation:\n");
    for(i = 0; i < n; i++)
        printf("%d ", a[i]);

    return 0;
}
