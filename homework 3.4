#include <stdio.h>
#include <string.h>

int main() {
    char str[200], words[50][20];
    int count[50] = {0};
    int i = 0, j = 0, k, max = 0, index = 0;

    printf("Enter sentence:\n");
    getchar();
    fgets(str, sizeof(str), stdin);

    char *token = strtok(str, " \n");
    while(token != NULL) {
        strcpy(words[i], token);
        count[i] = 1;
        for(j = 0; j < i; j++) {
            if(strcmp(words[j], token) == 0) {
                count[j]++;
                count[i] = 0;
                break;
            }
        }
        i++;
        token = strtok(NULL, " \n");
    }

    for(j = 0; j < i; j++) {
        if(count[j] > max) {
            max = count[j];
            index = j;
        }
    }

    printf("Most frequent word: %s", words[index]);
    return 0;
}
